if [[ -f  ~/.git-prompt.sh ]]; then
    . ~/.git-prompt.sh
fi

black='\[\e[1;30m\]'
red='\[\e[1;31m\]'
green='\[\e[1;32m\]'
yellow='\[\e[1;33m\]'
blue='\[\e[1;34m\]'
magenta='\[\e[1;35m\]'
cyan='\[\e[1;36m\]'
white='\[\e[1;37m\]'

reset='\[\e[0m\]'

# record last command exit status for use in PS1
# Capture last exit status FIRST
__prompt_command() {
    local last_exit=$?

    if (( last_exit < 10 )); then
        codefmt="[ ${last_exit} ]"
    elif (( last_exit < 100 )); then
        codefmt="[ ${last_exit}]"
    else
        codefmt="[${last_exit}]"
    fi

    if (( last_exit == 0 )); then
        codecol=$green # '\[\e[1;32m\]'
    else
        codecol=$red # '\[\e[1;31m\]'
    fi

    folder="${PWD##*/}"

    suffix='$'
    (( EUID == 0 )) && suffix='#'

    git_part="$(__git_ps1 " ${magenta}(${yellow}%s${magenta})${reset}")"

    PS1="${codecol}${codefmt}${reset} ${blue}${folder}/${reset}${git_part} ${suffix} "
}

# PREPEND our handler so $? is still the real command status
PROMPT_COMMAND="__prompt_command${PROMPT_COMMAND:+;}${PROMPT_COMMAND}"
